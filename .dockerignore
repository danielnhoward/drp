# Dependencies are reinstalled inside the image (deps stage). Copying the
# host's node_modules would overwrite the musl/Alpine build with glibc one.
node_modules

# Build output is regenerated by `pnpm build` in the builder stage.
.next
out
build

# Local SQLite data should never be baked into the image.
data
*.db
*.db-shm
*.db-wal

# VCS, env, and editor noise.
.git
.gitignore
.env*
*.tsbuildinfo
.DS_Store

# Docker files themselves.
Dockerfile
.dockerignore
